                  "id": "3302bf75-6dac-4cea-b9f2-ade6ef98b522",
                  "version": "KqlParameterItem/1.0",
                  "name": "Q3",
                  "label": "3️⃣ Does the data source have a REST API?",
                  "type": 10,
                  "isRequired": true,
                  "typeSettings": {
